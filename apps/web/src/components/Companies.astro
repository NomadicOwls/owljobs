---
import { supabasePublic } from "../lib/supabase.js";
import { listEmployers } from "../lib/jobs.js";
import { getEnv } from "../lib/env.js";

const niche = Astro.locals.niche;
const env = getEnv(Astro.locals);
const db = supabasePublic(env);

let employers: Array<{ name: string; normalized_name: string }> = [];
try {
  employers = await listEmployers(db, niche.supabaseSchema, 8);
} catch {
  // silently skip — section just won't render if DB is unavailable
}

if (employers.length === 0) return;

const nicheTopic = niche.name.replace(" Jobs", "").toLowerCase();
---

<section id="companies" class="border-y border-border bg-card/30 py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="mb-8 text-center text-xs font-semibold uppercase tracking-widest text-muted-foreground">
      Trusted by leading {nicheTopic} employers
    </p>

    <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12 lg:gap-16">
      {employers.map((emp) => (
        <a
          href={`/employers/${emp.normalized_name}`}
          class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground hover:no-underline"
        >
          {emp.name}
        </a>
      ))}
    </div>
  </div>
</section>
