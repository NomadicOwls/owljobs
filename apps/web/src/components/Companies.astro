---
import { getEnv } from "../lib/env.js";

const niche = Astro.locals.niche;
const { LOGODEV_TOKEN } = getEnv(Astro.locals);

type Employer = { name: string; domain: string };
const employers: Employer[] = niche.featuredEmployers ?? [];

if (employers.length === 0) return;

const nicheTopic = niche.name.replace(" Jobs", "").toLowerCase();
---

<section id="companies" class="border-y border-border bg-card/30 py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="mb-8 text-center text-xs font-semibold uppercase tracking-widest text-muted-foreground">
      Trusted by leading {nicheTopic} employers
    </p>

    <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12">
      {employers.map((emp) => (
        <div class="group flex items-center" title={emp.name}>
          <img
            src={`https://img.logo.dev/${emp.domain}?token=${LOGODEV_TOKEN}&size=60&format=png`}
            alt={emp.name}
            width="120"
            height="40"
            class="max-h-8 w-auto object-contain opacity-50 grayscale transition-all duration-200 group-hover:opacity-100 group-hover:grayscale-0"
            onerror="this.style.display='none';this.nextElementSibling.style.display='inline'"
          />
          <span class="hidden text-sm font-medium text-muted-foreground">
            {emp.name}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
