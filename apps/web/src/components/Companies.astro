---
import { supabasePublic } from "../lib/supabase.js";
import { listEmployers } from "../lib/jobs.js";
import { getEnv } from "../lib/env.js";

const niche = Astro.locals.niche;
const env = getEnv(Astro.locals);
const db = supabasePublic(env);

const AGGREGATORS = new Set(["adzuna", "jsearch"]);

let employers: Array<{ name: string; normalized_name: string }> = [];
try {
  const all = await listEmployers(db, niche.supabaseSchema, 16);
  employers = all.filter((e) => !AGGREGATORS.has(e.normalized_name.toLowerCase()));
} catch {
  // silently skip — section just won't render if DB is unavailable
}

if (employers.length === 0) return;

const nicheTopic = niche.name.replace(" Jobs", "").toLowerCase();

function logoUrl(normalized: string) {
  const domain = normalized.replace(/-/g, "") + ".com";
  return `https://logo.clearbit.com/${domain}`;
}
---

<section id="companies" class="border-y border-border bg-card/30 py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="mb-8 text-center text-xs font-semibold uppercase tracking-widest text-muted-foreground">
      Trusted by leading {nicheTopic} employers
    </p>

    <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12">
      {employers.map((emp) => (
        <a
          href={`/employers/${emp.normalized_name}`}
          class="group flex items-center hover:no-underline"
          title={emp.name}
        >
          <img
            src={logoUrl(emp.normalized_name)}
            alt={emp.name}
            width="120"
            height="40"
            class="max-h-8 w-auto object-contain opacity-50 grayscale transition-all duration-200 group-hover:opacity-100 group-hover:grayscale-0"
            onerror="this.style.display='none';this.nextElementSibling.style.display='inline'"
          />
          <span class="hidden text-sm font-medium text-muted-foreground transition-colors group-hover:text-foreground">
            {emp.name}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
