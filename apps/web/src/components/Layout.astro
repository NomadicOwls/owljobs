---
import "../styles/global.css";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import type { NicheConfig } from "@owljobs/niches";

export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: "website" | "article";
}

const {
  title,
  description,
  canonicalUrl,
  ogImage = "/og-default.png",
  ogType = "website",
} = Astro.props;

const niche: NicheConfig = Astro.locals.niche;
const pageTitle = title === niche.name ? title : `${title} — ${niche.name}`;
const fullCanonical = canonicalUrl ?? `https://${niche.domain}${Astro.url.pathname}`;

// Niche brand override: applied at <html> level so it cascades over both :root (light)
// and .dark token definitions. Only override accent/ring/primary — NOT background/card/muted
// which must follow the user's light/dark mode choice.
const nicheStyle = `--accent:${niche.branding.accentColor};--ring:${niche.branding.accentColor};--primary:${niche.branding.primaryColor};`;
---

<!doctype html>
<html lang="en" style={nicheStyle}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={fullCanonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:image" content={`https://${niche.domain}${ogImage}`} />
    <meta property="og:site_name" content={niche.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={`https://${niche.domain}${ogImage}`} />

    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="alternate" type="application/rss+xml" title={`${niche.name} Jobs`} href="/feed.xml" />

    <!-- No-flash theme script: runs synchronously before first paint to avoid flicker -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (t === "dark" || (!t && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
            document.documentElement.classList.add("dark");
          } else {
            document.documentElement.classList.remove("dark");
          }
        } catch (e) {}
      })();
    </script>
  </head>

  <body class="min-h-screen bg-background font-sans text-foreground antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
