---
import JobCardModern from "./JobCardModern.astro";
import FeaturedJobCard from "./FeaturedJobCard.astro";
import type { JobWithEmployer } from "../lib/jobs.js";

interface Props {
  title: string;
  breadcrumb?: Array<{ label: string; href: string }> | undefined;
  formAction: string;
  q?: string | undefined;
  country?: string | undefined;
  fixedLocation?: string | undefined;
  jobs: JobWithEmployer[];
  total: number;
  featuredJobs: JobWithEmployer[];
  pageNum: number;
  totalPages: number;
  isFallback?: boolean | undefined;
  fallbackLabel?: string | undefined;
  nicheName: string;
  seoFooter?: string | undefined;
}

const {
  title,
  breadcrumb,
  formAction,
  q,
  country,
  fixedLocation,
  jobs,
  total,
  featuredJobs,
  pageNum,
  totalPages,
  isFallback = false,
  fallbackLabel,
  nicheName,
  seoFooter,
} = Astro.props;

const hasActiveFilters = !!(q || country);

function buildUrl(p: number): string {
  const next = new URL(Astro.url);
  next.searchParams.set("page", String(p));
  return next.pathname + next.search;
}
---

<!-- Page header -->
<div class="border-b border-border bg-card/50">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    {breadcrumb && breadcrumb.length > 0 && (
      <nav class="mb-3 text-xs text-muted-foreground">
        {breadcrumb.map((crumb, i) => (
          <>
            {i > 0 && <span class="mx-1.5">›</span>}
            {i < breadcrumb.length - 1
              ? <a href={crumb.href} class="hover:text-foreground transition-colors hover:no-underline">{crumb.label}</a>
              : <span>{crumb.label}</span>
            }
          </>
        ))}
      </nav>
    )}
    <h1 class="mb-6 text-3xl font-bold text-foreground">{title}</h1>
    <form method="GET" action={formAction} class="flex flex-col gap-3 sm:flex-row">
      <div class="relative flex-1">
        <svg class="absolute left-3 top-1/2 h-5 w-5 -translate-y-1/2 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="search"
          name="q"
          value={q ?? ""}
          placeholder="Search by title or keyword…"
          class="h-12 w-full rounded-md border border-border bg-background pl-10 pr-3 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
        />
      </div>
      {country !== undefined && (
        <div class="relative flex-1 sm:max-w-xs">
          <svg class="absolute left-3 top-1/2 h-5 w-5 -translate-y-1/2 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.39 11.76a1 1 0 0 0 1.22 0C12.95 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/>
          </svg>
          <input
            type="text"
            name="country"
            value={country}
            placeholder="Country (e.g. US, DE)…"
            class="h-12 w-full rounded-md border border-border bg-background pl-10 pr-3 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
          />
        </div>
      )}
      <button
        type="submit"
        class="h-12 inline-flex items-center justify-center rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90 sm:px-4"
      >
        Search
      </button>
    </form>
  </div>
</div>

<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="flex gap-8">

    <!-- Desktop sidebar -->
    <aside class="hidden w-64 shrink-0 lg:block">
      <div class="sticky top-24 space-y-6">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-semibold text-foreground">Filters</h2>
          {hasActiveFilters && (
            <a href={formAction} class="text-xs text-accent hover:underline">Clear all</a>
          )}
        </div>

        <div class="space-y-3">
          <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Search</p>
          <form method="GET" action={formAction} class="space-y-2">
            <input
              type="search"
              name="q"
              value={q ?? ""}
              placeholder="Title or keyword…"
              class="h-9 w-full rounded-md border border-border bg-transparent px-3 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
            />
            {country !== undefined && (
              <input
                type="text"
                name="country"
                value={country}
                placeholder="Country (e.g. US, DE)…"
                class="h-9 w-full rounded-md border border-border bg-transparent px-3 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
              />
            )}
            <button type="submit" class="h-9 w-full rounded-md bg-primary text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
              Apply filters
            </button>
          </form>
        </div>

        {fixedLocation && (
          <div class="space-y-2">
            <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Location</p>
            <div class="inline-flex items-center gap-1.5 rounded-md border border-accent/40 bg-accent/10 px-3 py-1.5 text-xs font-medium text-accent">
              {fixedLocation}
            </div>
          </div>
        )}

        {fixedLocation && (
          <a href="/jobs" class="block text-xs text-muted-foreground hover:text-foreground transition-colors hover:no-underline">
            ← View all {nicheName.toLowerCase()}
          </a>
        )}
      </div>
    </aside>

    <!-- Main content -->
    <div class="min-w-0 flex-1">

      <!-- Result count + active filter chips -->
      <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
        {isFallback ? (
          <div class="w-full rounded-md border border-border bg-muted/40 px-4 py-3 text-sm text-muted-foreground">
            No jobs matched <span class="font-medium text-foreground">{fallbackLabel}</span> — showing <span class="font-medium text-foreground">{total.toLocaleString()}</span> recent {nicheName.toLowerCase()} positions instead.
          </div>
        ) : (
          <p class="text-sm text-muted-foreground">
            <span class="font-medium text-foreground">{total.toLocaleString()}</span> jobs found
          </p>
        )}

        {hasActiveFilters && (
          <div class="flex flex-wrap items-center gap-2">
            {q && (
              <a
                href={country !== undefined ? `${formAction}?country=${encodeURIComponent(country)}` : formAction}
                class="inline-flex items-center gap-1 rounded-md border border-border bg-secondary px-2 py-1 text-xs text-foreground hover:bg-secondary/80 hover:no-underline transition-colors"
              >
                {q}
                <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
              </a>
            )}
            {country && (
              <a
                href={q ? `${formAction}?q=${encodeURIComponent(q)}` : formAction}
                class="inline-flex items-center gap-1 rounded-md border border-border bg-secondary px-2 py-1 text-xs text-foreground hover:bg-secondary/80 hover:no-underline transition-colors"
              >
                {country}
                <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Featured jobs (page 1 only) -->
      {featuredJobs.length > 0 && pageNum === 1 && (
        <div class="grid gap-4 mb-6">
          {featuredJobs.map((job) => (
            <FeaturedJobCard job={job} />
          ))}
        </div>
      )}

      <!-- Job list -->
      {jobs.length > 0 ? (
        <div class="grid gap-4">
          {jobs.map((job, index) => (
            <JobCardModern job={job} index={index} />
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center rounded-xl border border-border bg-card py-16 text-center">
          <svg class="h-12 w-12 text-muted-foreground/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
          </svg>
          <p class="mt-4 text-base font-medium text-foreground">No jobs found</p>
          <p class="mt-1 text-sm text-muted-foreground">
            {hasActiveFilters ? "Try broadening your search or clearing filters." : "New roles are added hourly. Check back soon."}
          </p>
          <a href="/jobs" class="mt-6 inline-flex items-center rounded-md border border-border px-4 py-2 text-sm font-medium text-foreground hover:bg-secondary hover:no-underline transition-colors">
            {hasActiveFilters ? "Clear all filters" : "Browse all jobs"}
          </a>
        </div>
      )}

      <!-- Pagination -->
      {totalPages > 1 && (
        <nav class="mt-10 flex items-center justify-center gap-4 border-t border-border pt-8" aria-label="Pagination">
          {pageNum > 1 && (
            <a href={buildUrl(pageNum - 1)} class="rounded-md border border-border px-4 py-2 text-sm font-medium text-muted-foreground transition-colors hover:border-accent/50 hover:text-foreground hover:no-underline">
              ← Previous
            </a>
          )}
          <span class="text-sm text-muted-foreground">Page {pageNum} of {totalPages}</span>
          {pageNum < totalPages && (
            <a href={buildUrl(pageNum + 1)} class="rounded-md border border-border px-4 py-2 text-sm font-medium text-muted-foreground transition-colors hover:border-accent/50 hover:text-foreground hover:no-underline">
              Next →
            </a>
          )}
        </nav>
      )}
    </div>
  </div>
</div>

{seoFooter && (
  <section class="mx-auto max-w-3xl px-4 pb-16 text-center text-sm text-muted-foreground">
    <p>{seoFooter}</p>
  </section>
)}
