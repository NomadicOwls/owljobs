---
import Badge from "./ui/Badge.astro";
import { slugFromId } from "../lib/slug.js";
import { relativeDate } from "../lib/relative-date.js";
import type { JobWithEmployer } from "../lib/jobs.js";

export interface Props {
  job: JobWithEmployer;
  index?: number;
}

const { job, index = 0 } = Astro.props;
const slug = slugFromId(job.id);
const postedAgo = relativeDate(job.posted_at);
const isFeatured = job.is_sponsored || (job.featured_until ? new Date(job.featured_until) > new Date() : false);

// Two-letter employer initials for the logo tile
const employerName = job.employers?.name ?? "?";
const initials = employerName
  .split(/\s+/)
  .filter(Boolean)
  .map((w: string) => w[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();
---

<a
  href={`/jobs/${slug}`}
  class="group block no-underline hover:no-underline"
  style={`animation-delay: ${index * 40}ms`}
>
  <article class:list={[
    "relative rounded-xl border p-5 transition-all",
    isFeatured
      ? "border-accent/30 bg-card"
      : "border-border bg-card/50 hover:border-accent/50 hover:bg-card",
  ]}>
    {isFeatured && (
      <div class="absolute -top-2.5 left-4">
        <span class="inline-flex items-center rounded-md bg-accent px-2 py-0.5 text-xs font-medium text-accent-foreground">Featured</span>
      </div>
    )}

    <div class="flex gap-4">
      <!-- Employer initials tile -->
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg border border-border bg-secondary text-sm font-semibold text-muted-foreground">
        {initials}
      </div>

      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-start justify-between gap-2">
          <div>
            <h3 class="font-semibold text-foreground transition-colors group-hover:text-accent">
              {job.title}
            </h3>
            <div class="mt-1 flex items-center gap-1.5 text-sm text-muted-foreground">
              <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
              {employerName}
            </div>
          </div>
          {postedAgo && <span class="text-xs text-muted-foreground">{postedAgo}</span>}
        </div>

        {job.location && (
          <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
            <span class="flex items-center gap-1">
              <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              {job.location}
            </span>
          </div>
        )}
      </div>
    </div>
  </article>
</a>
