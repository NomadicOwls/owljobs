---
import { relativeDate } from "../lib/relative-date.js";

export interface Props {
  job?: import("../lib/jobs.js").JobWithEmployer;
  // Legacy props kept for call sites that haven't migrated to the job prop
  employer?: string;
  title?: string;
  location?: string;
  salary?: string;
  jobType?: string;
  postedAgo?: string;
  applyUrl?: string;
  href?: string;
  tags?: string[];
}

const { job, ...legacy } = Astro.props as Props;

const employer = job?.employers?.name ?? legacy.employer ?? "";
const title = job?.title ?? legacy.title ?? "";
const location = job?.location ?? legacy.location ?? "";
const href = job ? `/jobs/${job.id}` : (legacy.href ?? "/jobs");
const postedAgo = job?.posted_at ? relativeDate(job.posted_at) : (legacy.postedAgo ?? "");
const salary = legacy.salary ?? "";
const jobType = legacy.jobType ?? "";
const tags = legacy.tags ?? [];

const initials = employer
  .split(/\s+/)
  .filter(Boolean)
  .map((w: string) => w[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();
---

<a href={href} class="group block no-underline hover:no-underline">
  <article class="relative rounded-xl border border-accent/30 bg-card p-5 transition-all hover:border-accent/50 hover:bg-card/80">

    <!-- Floating Featured badge -->
    <div class="absolute -top-2 left-4">
      <span class="inline-flex items-center rounded-md bg-accent px-2 py-0.5 text-xs font-medium text-accent-foreground">
        Featured
      </span>
    </div>

    <div class="flex gap-4">
      <!-- Logo tile -->
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg border border-border bg-secondary text-sm font-semibold text-muted-foreground">
        {initials}
      </div>

      <div class="min-w-0 flex-1">
        <!-- Title + time -->
        <div class="flex flex-wrap items-start justify-between gap-2">
          <div>
            <h3 class="font-semibold text-foreground transition-colors group-hover:text-accent">
              {title}
            </h3>
            <div class="mt-1 flex items-center gap-1.5 text-sm text-muted-foreground">
              <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
              {employer}
            </div>
          </div>
          <span class="text-xs text-muted-foreground">{postedAgo}</span>
        </div>

        <!-- Meta: location · salary · type -->
        <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
          {location && (
            <span class="flex items-center gap-1">
              <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              {location}
            </span>
          )}
          {salary && (
            <span class="flex items-center gap-1">
              <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
              {salary}
            </span>
          )}
          {jobType && (
            <span class="flex items-center gap-1">
              <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
              </svg>
              {jobType}
            </span>
          )}
        </div>

        <!-- Skill tags -->
        {tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1.5">
            {tags.map((tag) => (
              <span class="rounded-md bg-secondary px-2 py-0.5 text-xs text-secondary-foreground">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>
  </article>
</a>
