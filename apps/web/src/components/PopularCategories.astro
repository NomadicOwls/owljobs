---
const niche = Astro.locals.niche;

const specializations = (niche.landingPages ?? []).filter(
  (p) => p.filters && "keywords" in p.filters
);
---

{specializations.length > 0 && (
  <section class="border-b border-border py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg font-semibold text-foreground">Popular specializations</h2>
      <div class="mt-4 flex flex-wrap gap-3">
        {specializations.map((page) => (
          <a
            href={`/${page.slug}`}
            class="inline-flex items-center rounded-full border border-border bg-card px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-accent hover:bg-accent/10 hover:text-accent-foreground hover:no-underline"
          >
            {page.label}
          </a>
        ))}
      </div>
    </div>
  </section>
)}
