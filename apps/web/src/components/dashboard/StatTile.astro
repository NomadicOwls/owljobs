---
interface Props {
  label: string;
  value: number | null;
  subLabel?: string;
}
const { label, value, subLabel } = Astro.props;
const display = value === null ? "—" : new Intl.NumberFormat("en-US").format(value);
const fallbackSub = value === null ? "Stats temporarily unavailable." : (subLabel ?? "");
---
<div class="bg-card rounded-xl border border-border p-6 shadow-sm">
  <p class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">{label}</p>
  <p class="mt-2 text-2xl font-semibold tabular-nums">{display}</p>
  {fallbackSub && <p class="mt-1 text-sm text-muted-foreground">{fallbackSub}</p>}
</div>
