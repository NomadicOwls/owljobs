---
const path = Astro.url.pathname;
function isCurrent(href: string) {
  return path === href ? "page" : undefined;
}
const items = [
  { href: "/dashboard", label: "Overview", icon: "overview" },
  { href: "/dashboard#jobs", label: "Jobs", icon: "jobs" },
  { href: "/dashboard#profile", label: "Profile", icon: "profile" },
  { href: "/api/auth/signout", label: "Sign out", icon: "signout" },
];
---
{/* Desktop left rail */}
<nav aria-label="Dashboard" class="hidden w-56 shrink-0 lg:block sticky top-24 self-start">
  <ul class="flex flex-col gap-1">
    {items.map((item) => (
      <li>
        <a
          href={item.href}
          aria-current={isCurrent(item.href)}
          class:list={[
            "flex items-center gap-3 rounded-md px-3 py-2 text-sm font-semibold",
            "focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2",
            isCurrent(item.href) ? "text-accent bg-accent/5" : "text-muted-foreground hover:text-foreground"
          ]}
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            {item.icon === "overview" && (<><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></>)}
            {item.icon === "jobs" && (<><path d="M20 7H4a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2Z" /><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" /></>)}
            {item.icon === "profile" && (<><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /></>)}
            {item.icon === "signout" && (<><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></>)}
          </svg>
          <span>{item.label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

{/* Mobile bottom-fixed nav — icon + label per item */}
<nav aria-label="Dashboard (mobile)" class="fixed bottom-0 left-0 right-0 border-t border-border bg-background/95 backdrop-blur lg:hidden z-40">
  <ul class="flex justify-around">
    {items.map((item) => (
      <li class="flex-1">
        <a
          href={item.href}
          aria-current={isCurrent(item.href)}
          class:list={[
            "flex flex-col items-center gap-1 py-2 px-3 min-h-14 text-sm font-semibold",
            "focus-visible:ring-2 focus-visible:ring-ring rounded-md",
            isCurrent(item.href) ? "text-accent" : "text-muted-foreground"
          ]}
        >
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            {item.icon === "overview" && (<><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></>)}
            {item.icon === "jobs" && (<><path d="M20 7H4a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2Z" /><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" /></>)}
            {item.icon === "profile" && (<><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /></>)}
            {item.icon === "signout" && (<><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></>)}
          </svg>
          <span>{item.label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>
