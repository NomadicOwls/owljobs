---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<div class="bg-card rounded-xl border border-border p-6 relative">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-base font-semibold leading-tight">{title}</h3>
    <span class="inline-flex items-center rounded-md bg-secondary px-2 py-1 text-sm font-semibold text-muted-foreground">
      Paid plan
    </span>
  </div>
  <div class="opacity-60 pointer-events-none select-none">
    <slot />
  </div>
  <p class="mt-4 text-sm text-muted-foreground">
    Available on paid plan — coming in Phase 5.
  </p>
</div>
