---
import DashboardLayout from "../components/dashboard/DashboardLayout.astro";
import EmployerLogo from "../components/employer/EmployerLogo.astro";
import StatTile from "../components/dashboard/StatTile.astro";
import JobRow from "../components/dashboard/JobRow.astro";
import LockedFeatureCard from "../components/dashboard/LockedFeatureCard.astro";
import ProfileEditorPreview from "../components/dashboard/ProfileEditorPreview.astro";
import LogoUploadPreview from "../components/dashboard/LogoUploadPreview.astro";
import SubscriberMatchCard from "../components/dashboard/SubscriberMatchCard.astro";
import { createSupabaseServerClient, supabaseAdmin } from "../lib/supabase.js";
import { getEnv } from "../lib/env.js";

const niche = Astro.locals.niche;
const session = Astro.locals.session;
const employerId = Astro.locals.employerId;

// PROF-04: gate to authenticated employers only
if (!session) return Astro.redirect("/login");
if (!employerId) return Astro.redirect("/employers");

const env = getEnv(Astro.locals);
// BL-03: use authenticated SSR client so RLS jobs_employer_read_own policy passes
const db = createSupabaseServerClient(
  env,
  Astro.request.headers.get("cookie"),
  Astro.response.headers,
);

const { data: employer } = await db
  .schema(niche.supabaseSchema)
  .from("employers")
  .select("id, name, slug, domain, normalized_name, website_url")
  .eq("id", employerId)
  .single();

if (!employer) return Astro.redirect("/employers");

const { data: ownJobs } = await db
  .schema(niche.supabaseSchema)
  .from("jobs")
  .select("id, title, location, status, posted_at, featured_until, canonical_url")
  .eq("employer_id", employerId)
  .order("posted_at", { ascending: false })
  .limit(50);

const jobs = ownJobs ?? [];
const userEmail = session.user.email ?? "";

// Server-side fetch of stats — forward session cookie so /api/stats can auth the request
let stats: { views: number; clicks: number; applies: number; perJob: Record<string, { views: number; clicks: number; applies: number }> } | null = null;
try {
  const statsResp = await fetch(`${Astro.url.origin}/api/stats?employer_id=${encodeURIComponent(employerId)}`, {
    headers: { cookie: Astro.request.headers.get("cookie") ?? "" },
  });
  if (statsResp.ok) stats = await statsResp.json();
} catch {
  // graceful degradation — stats will render as null (shows "—" in StatTile)
}

// Subscriber count — use supabaseAdmin because subscribers table has RLS with no anon SELECT policy.
// Only counting rows (no PII crossing the boundary).
const adminDb = supabaseAdmin(env);
const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
const { count: subscriberCount } = await adminDb
  .schema(niche.supabaseSchema)
  .from("subscribers")
  .select("id", { count: "exact", head: true })
  .gte("confirmed_at", sevenDaysAgo);

const { count: totalSubscribers } = await adminDb
  .schema(niche.supabaseSchema)
  .from("subscribers")
  .select("id", { count: "exact", head: true })
  .not("confirmed_at", "is", null);

// Do NOT set cache headers on /dashboard — per UI-SPEC §Cache headers, auth pages MUST NOT cache.
---
<DashboardLayout title={`${employer.name} — Dashboard`} description="Your employer dashboard">
  {/* 1. Greeting row */}
  <section class="mb-8 flex items-center gap-4 flex-wrap">
    <EmployerLogo name={employer.name} domain={employer.domain} size="lg" />
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl font-semibold leading-tight">{employer.name}</h1>
      <p class="text-sm text-muted-foreground">Signed in as {userEmail}</p>
    </div>
  </section>

  {/* 2. Stats row + 3. Subscriber match card */}
  <div data-dashboard-stats data-employer-id={employer.id} class="mb-8">
    <p class="text-sm font-semibold uppercase tracking-wider text-muted-foreground mb-3">Last 30 days</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <StatTile label="Views" value={stats?.views ?? null} />
      <StatTile label="Clicks" value={stats?.clicks ?? null} />
      <StatTile label="Apply clicks" value={stats?.applies ?? null} />
    </div>
    <div class="mt-6">
      {totalSubscribers !== null ? (
        <SubscriberMatchCard
          count={subscriberCount ?? 0}
          totalAudience={totalSubscribers}
          nicheName={niche.name}
        />
      ) : (
        <SubscriberMatchCard
          count={subscriberCount ?? 0}
          nicheName={niche.name}
        />
      )}
    </div>
  </div>

  {/* 4. Your jobs */}
  <section id="jobs" class="mb-8">
    <h2 class="text-xl font-semibold leading-tight">Your jobs</h2>
    <p class="mt-1 text-sm text-muted-foreground">
      Toggle Featured to pin a job to the top of the public listing. Featured slots are unlimited during the free trial — paid tier limits apply from Phase 5.
    </p>
    <div data-dashboard-jobs class="mt-4 grid gap-3">
      {jobs.length > 0 ? jobs.map((job) => {
        const j = stats?.perJob?.[job.id];
        return <JobRow job={job} views={j?.views ?? 0} clicks={j?.clicks ?? 0} applies={j?.applies ?? 0} />;
      }) : (
        <div class="bg-card rounded-xl border border-border p-6 text-center">
          <p class="text-base font-semibold">No active jobs</p>
          <p class="mt-1 text-sm text-muted-foreground">
            We're not seeing any open positions for {employer.name} right now. New roles appear here automatically when we detect them on your careers page.
          </p>
        </div>
      )}
    </div>
  </section>

  {/* 5. Profile (locked) */}
  <section id="profile" class="mb-8">
    <h2 class="text-xl font-semibold leading-tight">Company profile</h2>
    <p class="mt-1 text-sm text-muted-foreground">
      Profile editing and logo upload unlock with any paid plan (Phase 5). Preview the form below.
    </p>
    <div data-dashboard-profile class="mt-4 grid gap-6 md:grid-cols-2">
      <LockedFeatureCard title="Profile editor">
        <ProfileEditorPreview employer={employer} />
      </LockedFeatureCard>
      <LockedFeatureCard title="Logo">
        <LogoUploadPreview employer={employer} />
      </LockedFeatureCard>
    </div>
  </section>
</DashboardLayout>

<script>
  const toggles = document.querySelectorAll<HTMLButtonElement>("[data-featured-toggle]");
  toggles.forEach((btn) => {
    btn.addEventListener("click", async () => {
      const jobId = btn.dataset.jobId;
      if (!jobId) return;
      const pressed = btn.getAttribute("aria-pressed") === "true";
      const method = pressed ? "DELETE" : "POST";
      btn.disabled = true;
      try {
        const res = await fetch(`/api/jobs/${encodeURIComponent(jobId)}/featured`, {
          method,
          headers: { "Content-Type": "application/json" },
          ...(method === "POST" ? { body: "{}" } : {}),
        });
        if (!res.ok) throw new Error(String(res.status));
        const data = await res.json() as { featured_until: string | null };
        const newPressed = !!data.featured_until;
        btn.setAttribute("aria-pressed", newPressed ? "true" : "false");
        const label = btn.querySelector<HTMLElement>("[data-label]");
        if (label) label.textContent = newPressed ? "Featured" : "Feature job";
        btn.className = btn.className
          .replace(/bg-accent[^\s]*/g, "")
          .replace(/text-accent-foreground/g, "")
          .replace(/border-transparent/g, "")
          .trim();
        if (newPressed) {
          btn.classList.add("bg-accent", "text-accent-foreground", "border-transparent");
        } else {
          btn.classList.add("border-border", "bg-background", "text-muted-foreground");
        }
      } catch {
        // Show error pill below the button
        const errPill = document.createElement("p");
        errPill.className = "mt-2 bg-destructive/10 text-destructive border border-destructive/30 rounded-md p-2 text-sm";
        errPill.textContent = "Couldn't update Featured status. Try again.";
        btn.parentElement?.appendChild(errPill);
        setTimeout(() => errPill.remove(), 5000);
      } finally {
        btn.disabled = false;
      }
    });
  });
</script>
