---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import Companies from "../components/Companies.astro";
import Stats from "../components/Stats.astro";
import JobListings from "../components/JobListings.astro";
import Newsletter from "../components/Newsletter.astro";
import { supabasePublic } from "../lib/supabase.js";
import { listJobs } from "../lib/jobs.js";
import { setCacheHeaders } from "../lib/cache.js";
import { getEnv } from "../lib/env.js";

const { niche } = Astro.locals;
const env = getEnv(Astro.locals);

setCacheHeaders(Astro.response.headers, 300, 600);

const db = supabasePublic(env);
const confirmed = Astro.url.searchParams.get("confirmed") === "1";

let jobs: Awaited<ReturnType<typeof listJobs>>["jobs"] = [];
let total = 0;

try {
  const result = await listJobs(db, niche.supabaseSchema, { perPage: 6 });
  jobs = result.jobs;
  total = result.total;
} catch {
  // silently degrade — sections render with empty state
}
---

<Layout
  title={niche.name}
  description={`${niche.tagline} — find your next role from the best employers.`}
>
  <Hero count={total} />
  <Companies />
  <Stats />
  <JobListings jobs={jobs} total={total} />
  <Newsletter siteKey={env.TURNSTILE_SITE_KEY} confirmed={confirmed} />
</Layout>
