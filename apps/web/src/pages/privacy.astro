---
import Layout from "../components/Layout.astro";
import { getEnv } from "../lib/env.js";

const { niche } = Astro.locals;
const env = getEnv(Astro.locals);
const turnstileSiteKey = env.TURNSTILE_SITE_KEY;
---

<Layout
  title="Privacy Policy"
  description={`How ${niche.name} collects, stores and processes your personal data.`}
>
  <div class="mx-auto max-w-2xl px-4 py-14 pb-20 sm:px-6">
    <div class="prose-content">
      <h1>Privacy Policy</h1>
      <p class="lead">This policy explains what personal data we collect, why we collect it, and your rights under the GDPR.</p>

      <h2>Who we are</h2>
      <p>
        {niche.name} is a job aggregation service that collects specialist roles
        from publicly available employer career pages and presents them in one place.
      </p>

      <h2>Data we collect</h2>
      <h3>Job alert subscribers</h3>
      <p>If you sign up for job alerts, we store:</p>
      <ul>
        <li>Your email address</li>
        <li>A confirmation status and timestamp</li>
        <li>A token to allow you to unsubscribe at any time</li>
        <li>Date of subscription</li>
      </ul>
      <p>
        We do not store your IP address, browser fingerprint, or any other identifying information.
      </p>
      <p>
        We collect this data on the basis of your consent. You can withdraw consent at any time
        by clicking the unsubscribe link in any email we send.
      </p>

      <h3>Server logs</h3>
      <p>
        Cloudflare (our infrastructure provider) processes request logs. This is covered by
        Cloudflare's own privacy policy and data processing agreement.
      </p>

      <h2>Sub-processors</h2>
      <table>
        <thead>
          <tr>
            <th>Processor</th>
            <th>Purpose</th>
            <th>DPA</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Resend</td>
            <td>Transactional email delivery (confirmation &amp; unsubscribe)</td>
            <td><a href="https://resend.com/legal/dpa" rel="noopener" target="_blank">resend.com/legal/dpa</a></td>
          </tr>
          <tr>
            <td>Supabase</td>
            <td>Database (subscriber email + token storage)</td>
            <td><a href="https://supabase.com/privacy" rel="noopener" target="_blank">supabase.com/privacy</a></td>
          </tr>
          <tr>
            <td>Cloudflare</td>
            <td>Edge hosting, CDN, Turnstile spam protection</td>
            <td><a href="https://www.cloudflare.com/gdpr/introduction/" rel="noopener" target="_blank">cloudflare.com/gdpr</a></td>
          </tr>
        </tbody>
      </table>

      <h2>Data retention</h2>
      <p>
        Subscriber records are kept until you unsubscribe. Unsubscribed records are deleted immediately.
        Unconfirmed records (where you signed up but never clicked the confirmation link) are purged after 30 days.
      </p>

      <h2>Your rights</h2>
      <p>Under the GDPR you have the right to:</p>
      <ul>
        <li>Access a copy of your personal data</li>
        <li>Request correction of inaccurate data</li>
        <li>Request deletion ("right to be forgotten")</li>
        <li>Withdraw consent at any time (unsubscribe link in every email)</li>
      </ul>
      <p>
        To exercise any right, email us at <a href={`mailto:privacy@${niche.domain}`}>{`privacy@${niche.domain}`}</a>.
      </p>

      <h2>Cookies &amp; tracking</h2>
      <p>
        We do not set any tracking or advertising cookies. We do not use Google Analytics or any
        third-party analytics that processes personal data. We may add privacy-safe analytics
        (Cloudflare Web Analytics or Plausible) that do not use cookies and do not collect
        personal data — no consent banner required.
      </p>

      <h2>Job listings</h2>
      <p>
        Job listings are aggregated from publicly available employer career pages. We do not store
        any candidate data submitted to employers. When you click "Apply", you are taken directly
        to the employer's site.
      </p>

      <p class="updated">Last updated: May 2025</p>
    </div>

    <section class="mt-12 pt-8 border-t border-border">
      <h2 class="text-xl font-bold text-foreground">Request data deletion</h2>
      <p class="mt-2 text-sm text-muted-foreground">
        Under GDPR Article 17 you may request that we delete all personal data we hold
        about you. Submit your email below and we will process the request within 30 days.
      </p>
      <form
        id="delete-form"
        novalidate
        class="mt-4 space-y-3"
        data-turnstile-key={turnstileSiteKey}
      >
        <input
          type="email"
          name="email"
          id="delete-email"
          placeholder="your@email.com"
          required
          autocomplete="email"
          class="h-12 w-full rounded-md border border-border bg-background px-3 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
        />
        <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>
        <button
          type="submit"
          id="delete-submit"
          class="inline-flex h-12 items-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90 disabled:opacity-50 disabled:pointer-events-none"
        >
          Submit request
        </button>
        <p id="delete-error" class="text-sm text-destructive min-h-[1.25rem]" role="alert" aria-live="polite"></p>
        <p id="delete-success" class="text-sm text-accent min-h-[1.25rem]" role="status" aria-live="polite"></p>
      </form>
    </section>
  </div>
</Layout>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

<script>
  const f = document.getElementById("delete-form") as HTMLFormElement | null;
  if (f) {
    f.addEventListener("submit", async (e) => {
      e.preventDefault();
      const emailEl = document.getElementById("delete-email") as HTMLInputElement | null;
      const errEl = document.getElementById("delete-error");
      const okEl = document.getElementById("delete-success");
      const submitEl = document.getElementById("delete-submit") as HTMLButtonElement | null;
      if (!emailEl || !errEl || !okEl || !submitEl) return;

      errEl.textContent = "";
      okEl.textContent = "";

      const email = emailEl.value.trim();
      if (!email) {
        errEl.textContent = "Please enter your email address.";
        return;
      }

      const tokenInput = f.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]');
      const turnstileToken = tokenInput?.value ?? "";

      submitEl.disabled = true;

      try {
        const res = await fetch("/api/delete-request", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, turnstileToken }),
        });
        const json = (await res.json()) as { message?: string; error?: string };
        if (res.ok) {
          okEl.textContent = json.message ?? "We received your request and will process it within 30 days.";
          f.reset();
          if (typeof (window as any).turnstile !== "undefined") {
            (window as any).turnstile.reset();
          }
        } else {
          errEl.textContent = json.error ?? "Something went wrong. Try again.";
        }
      } catch {
        errEl.textContent = "Network error. Please try again.";
      } finally {
        submitEl.disabled = false;
      }
    });
  }
</script>

<style>
  .prose-content {
    line-height: 1.75;
    color: var(--muted-foreground);
  }
  .prose-content h1 {
    font-size: clamp(1.875rem, 5vw, 2.5rem);
    font-weight: 800;
    color: var(--foreground);
    margin: 0 0 0.5rem;
    letter-spacing: -0.025em;
  }
  .prose-content .lead {
    font-size: 1rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.5rem;
  }
  .prose-content h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--foreground);
    margin: 2.25rem 0 0.625rem;
    letter-spacing: -0.015em;
  }
  .prose-content h3 {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--foreground);
    margin: 1.5rem 0 0.4rem;
  }
  .prose-content p,
  .prose-content li {
    font-size: 0.9375rem;
  }
  .prose-content ul {
    padding-left: 1.25rem;
  }
  .prose-content li {
    margin-bottom: 0.3rem;
  }
  .prose-content table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    margin: 1rem 0 1.5rem;
  }
  .prose-content th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    background: var(--secondary);
    font-weight: 700;
    color: var(--foreground);
    border-bottom: 1px solid var(--border);
  }
  .prose-content td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .prose-content a {
    color: var(--accent);
    text-decoration: none;
  }
  .prose-content a:hover {
    text-decoration: underline;
  }
  .prose-content .updated {
    font-size: 0.8rem;
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
</style>
